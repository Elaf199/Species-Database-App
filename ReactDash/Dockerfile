FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_API_BASE
ARG VITE_API_URL
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_PUBLISHABLE_KEY
ARG VITE_SUPABASE_URL_TETUM
ARG VITE_SUPABASE_PUBLISHABLE_KEY_TETUM
ARG VITE_GOOGLE_CLIENT_ID

ENV VITE_API_BASE=$VITE_API_BASE \
    VITE_API_URL=$VITE_API_URL \
    VITE_SUPABASE_URL=$VITE_SUPABASE_URL \
    VITE_SUPABASE_PUBLISHABLE_KEY=$VITE_SUPABASE_PUBLISHABLE_KEY \
    VITE_SUPABASE_URL_TETUM=$VITE_SUPABASE_URL_TETUM \
    VITE_SUPABASE_PUBLISHABLE_KEY_TETUM=$VITE_SUPABASE_PUBLISHABLE_KEY_TETUM \
    VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID

COPY ReactDash/package*.json ./
RUN npm ci

COPY ReactDash ./
RUN npm run build

FROM nginx:1.27-alpine

COPY ReactDash/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
